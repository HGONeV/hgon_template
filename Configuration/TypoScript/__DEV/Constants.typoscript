plugin.tx_hgonpayment {
    settings {
        api {
            # Muss leider sein: Unkorrekte URL, weil PayPal hier ein .local nicht akzeptiert und Fehler wirft
            cancelUrl = http://stage.hgon.de/mitmachen
        }
    }
}

# Module configuration
# sf_event_mgt / hCaptcha
# Official hCaptcha test keys for local development only
plugin.tx_sfeventmgt {
    settings {
        registration {
            captcha {
                hCaptcha {
                    publicKey = 10000000-ffff-ffff-ffff-000000000001
                    privateKey = 0x0000000000000000000000000000000000000000
                }
            }
        }
    }
}

